# Supabase Configuration (client — exposed to the browser)
# Get these from your Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Server-side only (Vercel Environment Variables) ─────────────────────────
# Used by the /api edge functions. DO NOT prefix with VITE_ and never expose
# the service-role key to the browser.

# Required by /api/invite-member.ts to send workspace invitations.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: pin the base URL used for invite redirect links (recommended in
# production so a spoofed Origin header can't redirect invitees elsewhere).
# Example: https://sastratech.live
APP_URL=
